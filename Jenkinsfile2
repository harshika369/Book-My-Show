pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'harshikaaa/bookmyshow:latest'
        DOCKER_CREDENTIALS = 'docker-creds'
        NVD_API_KEY = credentials('nvd-api-key')
    }

    tools {
        nodejs 'node18'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/harshika369/Book-My-Show.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('bookmyshow-app') {
                    script {
                        def scannerHome = tool 'sonar-scanner'
                        withSonarQubeEnv('sonar-server') {
                            withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                                sh """
                                ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectName=BMS \
                                -Dsonar.projectKey=bms-app \
                                -Dsonar.sources=. \
                                -Dsonar.host.url=$SONAR_HOST_URL \
                                -Dsonar.token=$SONAR_TOKEN
                                """
                            }
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('bookmyshow-app') {
                    sh '''
                    echo "Node version:"
                    node -v
                    npm -v

                    npm config set registry https://registry.npmjs.org/
                    npm config set fetch-retries 5
                    npm config set fetch-retry-factor 2
                    npm config set fetch-retry-mintimeout 20000
                    npm config set fetch-retry-maxtimeout 120000
                    npm config set fetch-timeout 600000

                    rm -rf node_modules package-lock.json
                    npm cache clean --force

                    npm install --legacy-peer-deps || npm install --legacy-peer-deps || npm install --legacy-peer-deps
                    '''
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        dir('bookmyshow-app') {
                            dependencyCheck additionalArguments: """
                                --scan .
                                --format XML
                                --format HTML
                                --nvdApiKey ${NVD_API_KEY}
                                --data /var/lib/jenkins/owasp-data
                                --disableYarnAudit
                                --disableNodeAudit
                            """, odcInstallation: 'DP-Check'

                            dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                        }
                    }
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --severity HIGH,CRITICAL bookmyshow-app || true'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE -f bookmyshow-app/Dockerfile bookmyshow-app'
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image --severity HIGH,CRITICAL $DOCKER_IMAGE || true'
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('', DOCKER_CREDENTIALS) {
                        sh 'docker push $DOCKER_IMAGE'
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                kubectl apply -f deployment.yml
                kubectl apply -f service.yml
                '''
            }
        }
    }

    post {
        success {
            emailext (
                subject: "SUCCESS: Build Passed ✅",
                body: "Pipeline executed successfully 🚀",
                to: "harshikabaliyanhs@gmail.com"
            )
        }

        unstable {
            emailext (
                subject: "UNSTABLE: Security Issues Found ⚠️",
                body: "Pipeline passed but vulnerabilities detected (OWASP/Trivy).",
                to: "harshikabaliyanhs@gmail.com"
            )
        }

        failure {
            emailext (
                subject: "FAILURE: Build Failed ❌",
                body: "Pipeline failed. Check Jenkins logs.",
                to: "harshikabaliyanhs@gmail.com"
            )
        }
    }
}
